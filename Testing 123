Sub PickDateFrom()
    Dim dt As Variant
    dt = Application.InputBox("Enter From Date (dd/mm/yyyy)", Type:=2)

    If IsDate(dt) Then
        Sheets("Dashboard").Range("C5").Value = CDate(dt)
    End If
End Sub

Sub PickDateTo()
    Dim dt As Variant
    dt = Application.InputBox("Enter To Date (dd/mm/yyyy)", Type:=2)

    If IsDate(dt) Then
        Sheets("Dashboard").Range("C6").Value = CDate(dt)
    End If
End Sub

Sub BrowseFolder()

    Dim fd As FileDialog

    Set fd = Application.FileDialog(msoFileDialogFolderPicker)

    If fd.Show = -1 Then
        Sheets("Dashboard").Range("C7").Value = fd.SelectedItems(1)
    End If

End Sub

Sub DownloadPDFs()

    Dim olApp As Object
    Dim ns As Object
    Dim inbox As Object
    Dim items As Object
    Dim filtered As Object
    Dim mail As Object
    Dim att As Object

    Dim ws As Worksheet
    Dim logWs As Worksheet

    Dim senderEmail As String
    Dim savePath As String
    Dim fromDt As Date
    Dim toDt As Date
    Dim folderName As String

    Dim filter As String
    Dim lastRow As Long
    Dim fileCount As Long
    Dim startTime As Double

    On Error GoTo ErrorHandler

    startTime = Timer

    Set ws = Sheets("Dashboard")
    Set logWs = Sheets("Download Log")

    senderEmail = Trim(ws.Range("C4").Value)
    fromDt = ws.Range("C5").Value
    toDt = ws.Range("C6").Value
    savePath = Trim(ws.Range("C7").Value)
    folderName = Trim(ws.Range("C8").Value)

    If Right(savePath, 1) <> "\" Then
        savePath = savePath & "\"
    End If

    On Error Resume Next
    Set olApp = GetObject(, "Outlook.Application")

    If olApp Is Nothing Then
        Set olApp = CreateObject("Outlook.Application")
    End If
    On Error GoTo ErrorHandler

    Set ns = olApp.GetNamespace("MAPI")
    Set inbox = ns.GetDefaultFolder(6)

    If folderName <> "" And LCase(folderName) <> "inbox" Then
        Set inbox = inbox.Folders(folderName)
    End If

    Set items = inbox.Items
    items.Sort "[ReceivedTime]", True

    filter = "[ReceivedTime] >= '" & _
             Format(fromDt, "mm/dd/yyyy hh:mm AMPM") & _
             "' AND [ReceivedTime] <= '" & _
             Format(toDt + 1, "mm/dd/yyyy hh:mm AMPM") & "'"

    Set filtered = items.Restrict(filter)

    fileCount = 0

    For Each mail In filtered

        If TypeName(mail) = "MailItem" Then

            If InStr(1, LCase(mail.SenderEmailAddress), _
            LCase(senderEmail)) > 0 Then

                If mail.Attachments.Count > 0 Then

                    For Each att In mail.Attachments

                        If LCase(Right(att.FileName, 4)) = ".pdf" Then

                            Dim finalPath As String

                            finalPath = savePath & _
                            Format(Now, "yyyymmdd_hhnnss_") & _
                            att.FileName

                            att.SaveAsFile finalPath

                            fileCount = fileCount + 1

                            lastRow = logWs.Cells(logWs.Rows.Count, 1).End(xlUp).Row + 1

                            logWs.Cells(lastRow, 1).Value = lastRow - 1
                            logWs.Cells(lastRow, 2).Value = Now
                            logWs.Cells(lastRow, 3).Value = mail.Subject
                            logWs.Cells(lastRow, 4).Value = mail.SenderEmailAddress
                            logWs.Cells(lastRow, 5).Value = att.FileName
                            logWs.Cells(lastRow, 6).Value = "Downloaded"
                            logWs.Cells(lastRow, 7).Value = finalPath

                        End If

                    Next att

                End If

            End If

        End If

    Next mail

    ws.Range("C22").Value = "Success"
    ws.Range("C23").Value = fileCount
    ws.Range("C24").Value = Now
    ws.Range("C25").Value = Round(Timer - startTime, 2) & " Seconds"

    MsgBox fileCount & " PDFs downloaded successfully."

    Exit Sub

ErrorHandler:
    ws.Range("C22").Value = "Failed"
    MsgBox Err.Description

End Sub