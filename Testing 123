Sub Create_Outlook_PDF_Downloader()

    Dim newWB As Workbook
    Dim wsDash As Worksheet
    Dim wsLog As Worksheet
    Dim savePath As String
    Dim vbProj As Object
    Dim vbComp As Object
    Dim codeMod As Object
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    'Create new workbook
    Set newWB = Workbooks.Add
    
    'Remove extra default sheets
    Do While newWB.Sheets.Count > 1
        newWB.Sheets(newWB.Sheets.Count).Delete
    Loop
    
    '-----------------------------------
    ' Dashboard Sheet
    '-----------------------------------
    Set wsDash = newWB.Sheets(1)
    wsDash.Name = "Dashboard"
    
    With wsDash
    
        .Range("A1:G1").Merge
        .Range("A1").Value = "OUTLOOK PDF ATTACHMENT DOWNLOADER"
        .Range("A1").HorizontalAlignment = xlCenter
        .Range("A1").Font.Bold = True
        .Range("A1").Font.Size = 14
        
        .Range("A3:G3").Merge
        .Range("A3").Value = "SETTINGS"
        .Range("A3").Font.Bold = True
        
        .Range("A4").Value = "Sender Email Address"
        .Range("A5").Value = "Date From"
        .Range("A6").Value = "Date To"
        .Range("A7").Value = "Save Folder Path"
        .Range("A8").Value = "Outlook Folder Name"
        
        .Range("C8").Value = "Inbox"
        
        .Range("A10:G10").Merge
        .Range("A10").Value = "HOW TO USE"
        .Range("A10").Font.Bold = True
        
        .Range("A11").Value = "Step 1"
        .Range("C11").Value = "Enter sender email"
        
        .Range("A12").Value = "Step 2"
        .Range("C12").Value = "Enter date range"
        
        .Range("A13").Value = "Step 3"
        .Range("C13").Value = "Select save folder"
        
        .Range("A14").Value = "Step 4"
        .Range("C14").Value = "Run download macro"
        
        .Range("A20:G20").Merge
        .Range("A20").Value = "STATUS"
        .Range("A20").Font.Bold = True
        
        .Range("A21").Value = "Last Run Status"
        .Range("A22").Value = "Files Downloaded"
        .Range("A23").Value = "Last Run Time"
        .Range("A24").Value = "Execution Time"
        
        .Columns("A:G").AutoFit
        
    End With
    
    '-----------------------------------
    ' Log Sheet
    '-----------------------------------
    Set wsLog = newWB.Sheets.Add(After:=wsDash)
    wsLog.Name = "Download Log"
    
    With wsLog
        .Range("A1").Value = "#"
        .Range("B1").Value = "Timestamp"
        .Range("C1").Value = "Email Subject"
        .Range("D1").Value = "Sender"
        .Range("E1").Value = "File Name"
        .Range("F1").Value = "Status"
        .Range("G1").Value = "Save Path"
        
        .Rows(1).Font.Bold = True
        .Columns("A:G").AutoFit
    End With
    
    '-----------------------------------
    ' Add VBA Module
    '-----------------------------------
    Set vbProj = newWB.VBProject
    Set vbComp = vbProj.VBComponents.Add(1)
    Set codeMod = vbComp.CodeModule
    
    codeMod.AddFromString _
    "Sub BrowseFolder()" & vbCrLf & _
    "Dim fd As FileDialog" & vbCrLf & _
    "Set fd = Application.FileDialog(msoFileDialogFolderPicker)" & vbCrLf & _
    "If fd.Show = -1 Then Sheets(""Dashboard"").Range(""C7"").Value = fd.SelectedItems(1)" & vbCrLf & _
    "End Sub"
    
    codeMod.AddFromString _
    "Sub DownloadPDFs()" & vbCrLf & _
    "MsgBox ""Download logic module inserted successfully. Add your final Outlook extraction logic here."", vbInformation" & vbCrLf & _
    "End Sub"
    
    '-----------------------------------
    ' Save file
    '-----------------------------------
    savePath = Application.GetSaveAsFilename( _
        FileFilter:="Excel Macro-Enabled Workbook (*.xlsm), *.xlsm")
    
    If savePath <> "False" Then
        newWB.SaveAs savePath, FileFormat:=52
        MsgBox "New Outlook PDF Downloader file created successfully.", vbInformation
    Else
        MsgBox "File creation cancelled."
    End If
    
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True

End Sub