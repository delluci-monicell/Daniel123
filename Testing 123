Sub ClearAllFilters()

    Dim ws As Worksheet
    Set ws = ActiveSheet

    ' Only works on Sheet 2 and Sheet 3
    If ws.Name <> "Sheet2" And ws.Name <> "Sheet3" Then
        MsgBox "This macro only works on Sheet 2 or Sheet 3!", vbExclamation
        Exit Sub
    End If

    ' Clear filters if active
    If ws.AutoFilterMode Then
        If ws.FilterMode Then
            ws.ShowAllData
            MsgBox "Filters cleared on: " & ws.Name, vbInformation
        Else
            MsgBox "No active filters to clear on: " & ws.Name, vbInformation
        End If
    Else
        MsgBox "AutoFilter is not enabled on: " & ws.Name, vbExclamation
    End If

End Sub


