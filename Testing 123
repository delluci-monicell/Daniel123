Sub ShowAll_ActiveSheet()

    Dim ws As Worksheet
    Set ws = ActiveSheet

    ' Unprotect safely
    On Error Resume Next
    ws.Unprotect Password:="YourPassword"
    On Error GoTo 0

    ' Handle normal range filters
    If ws.AutoFilterMode Then
        If ws.FilterMode Then
            On Error Resume Next
            ws.ShowAllData
            On Error GoTo 0
        End If
    End If

    ' Handle tables (important — most people forget this)
    Dim tbl As ListObject
    For Each tbl In ws.ListObjects
        If tbl.AutoFilter.FilterMode Then
            On Error Resume Next
            tbl.AutoFilter.ShowAllData
            On Error GoTo 0
        End If
    Next tbl

    ' Re-protect with proper permissions
    ws.Protect Password:="YourPassword", _
        AllowFiltering:=True, _
        AllowSorting:=True

End Sub
