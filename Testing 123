Sub ShowAll_ActiveSheet()

    Dim ws As Worksheet
    Set ws = ActiveSheet

    ' Unprotect
    On Error Resume Next
    ws.Unprotect Password:="YourPassword"
    On Error GoTo 0

    ' Clear normal filters
    If ws.AutoFilterMode Then
        If ws.FilterMode Then
            On Error Resume Next
            ws.ShowAllData
            On Error GoTo 0
        End If
    End If

    ' Clear table filters
    Dim tbl As ListObject
    For Each tbl In ws.ListObjects
        If tbl.AutoFilter.FilterMode Then
            On Error Resume Next
            tbl.AutoFilter.ShowAllData
            On Error GoTo 0
        End If
    Next tbl

    ' Re-protect EXACTLY like your screenshot
    ws.Protect Password:="YourPassword", _
        DrawingObjects:=True, _
        Contents:=True, _
        Scenarios:=True, _
        AllowSorting:=True, _
        AllowFiltering:=True, _
        AllowSelectingLockedCells:=True, _
        AllowSelectingUnlockedCells:=True

End Sub
