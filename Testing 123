Sub ClearAllFilters()

    Dim ws As Worksheet
    Set ws = ActiveSheet

    ' Only works on Sheet 2 and Sheet 3
    If ws.Name <> "Sheet2" And ws.Name <> "Sheet3" Then
        MsgBox "This macro only works on Sheet 2 or Sheet 3!", vbExclamation
        Exit Sub
    End If

    ' Clear filters if active
    If ws.AutoFilterMode Then
        If ws.FilterMode Then
            ws.ShowAllData
            MsgBox "Filters cleared on: " & ws.Name, vbInformation
        Else
            MsgBox "No active filters to clear on: " & ws.Name, vbInformation
        End If
    Else
        MsgBox "AutoFilter is not enabled on: " & ws.Name, vbExclamation
    End If

End Sub


Sub ProtectTargetSheets()

    Dim ws As Worksheet
    Dim sheetNames As Variant
    Dim i As Integer

    ' Your exact sheet tab names
    sheetNames = Array("Sheet2", "Sheet3")

    For i = 0 To UBound(sheetNames)
        Set ws = ThisWorkbook.Sheets(sheetNames(i))
        ws.Unprotect Password:="yourpassword"
        ws.Protect Password:="yourpassword", _
            DrawingObjects:=True, _
            Contents:=True, _
            Scenarios:=True, _
            AllowSorting:=True, _
            AllowFiltering:=True, _
            UserInterfaceOnly:=True
    Next i

    MsgBox "Sheet 2 and Sheet 3 protected successfully!", vbInformation

End Sub


Module 2 — Paste in ThisWorkbook module

Private Sub Workbook_Open()

    ' Re-protect Sheet 2 and 3 with UserInterfaceOnly every time file opens
    Call ProtectTargetSheets

End Sub


Setup Steps — Do this once:
	1.	Open VBA editor — Alt + F11
	2.	Insert → Module → paste the first block
	3.	Click ThisWorkbook on the left panel → paste the second block
	4.	Replace "Sheet2" and "Sheet3" with your exact sheet tab names
	5.	Replace "yourpassword" with your actual password (all 3 places)
	6.	Manually unprotect Sheet 2 and Sheet 3 from Review tab
	7.	Run ProtectTargetSheets macro once manually from Alt+F8
	8.	Add your Command Button on Sheet 2 and Sheet 3
	9.	Assign ClearAllFilters macro to both buttons
	10.	Save the file as .xlsm (macro enabled format)

