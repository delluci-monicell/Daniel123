Sub ShowAll_ActiveSheet()

    Dim ws As Worksheet
    Set ws = ActiveSheet

    Dim lastRow As Long

    On Error Resume Next
    ws.Unprotect Password:="Custody"
    On Error GoTo 0

    ' ===== CLEAR FILTERS =====
    If ws.AutoFilterMode Then
        If ws.FilterMode Then
            On Error Resume Next
            ws.ShowAllData
            On Error GoTo 0
        End If
    End If

    Dim tbl As ListObject
    For Each tbl In ws.ListObjects
        If tbl.AutoFilter.FilterMode Then
            On Error Resume Next
            tbl.AutoFilter.ShowAllData
            On Error GoTo 0
        End If
    Next tbl

    ' ===== LOCK LOGIC =====
    lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).Row

    ' First unlock everything (reset state)
    ws.Cells.Locked = False

    If ws.Name = "Request for Information" Then
        
        ' Lock A column
        ws.Range("A3:A" & lastRow).Locked = True
        
        ' Lock T to W
        ws.Range("T3:W" & lastRow).Locked = True

    ElseIf ws.Name = "Rejection" Then
        
        ' Lock X to Z
        ws.Range("X3:Z" & lastRow).Locked = True
        
        ' Lock AB to AC
        ws.Range("AB3:AC" & lastRow).Locked = True

    End If

    ' ===== PROTECT =====
    ws.Protect Password:="Custody", _
        DrawingObjects:=True, _
        Contents:=True, _
        Scenarios:=True, _
        AllowSorting:=True, _
        AllowFiltering:=True

    ' ===== CONTROL SELECTION =====
    ws.EnableSelection = xlUnlockedCells

End Sub
